 "query": "select\nb.warehouse,\ni.item_code,\ni.description,\nSUM(b.actual_qty),\nwd.rack,\nwd.bin\nfrom `tabBin` b\ninner join `tabItem` i on b.item_code = i.item_code\ninner join `tabWarehouse` w on w.name = b.warehouse\nleft outer join `tabWarehouse Details` wd on wd.parent = i.item_code and wd.warehouse = b.warehouse\nwhere b.actual_qty !=0\ngroup by b.warehouse,i.item_code",
