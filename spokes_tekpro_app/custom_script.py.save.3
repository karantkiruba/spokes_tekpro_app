        inner join `tabPurchase Order Item` pod on pod.parent = po.name
        where pod.item_code = i.item_code and pod.warehouse = wd.warehouse and po.status not in('Cancelled','Closed') and po.docstatus = 1) as "Po_pending_qty"
        FROM `tabItem` i
