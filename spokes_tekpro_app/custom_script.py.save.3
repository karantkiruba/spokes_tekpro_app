		 and (
		MONTH(dn.posting_date) = MONTH(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)) and YEAR(dn.posting_date)= YEAR(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)))),0) as "month_1",
