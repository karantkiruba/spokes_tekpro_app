		inner join `tabSales Team` st on st.parent = dn.name
		where st.sales_person = '{sales_person}' and dni.warehouse = wd.warehouse and dni.item_code = i.item_code 
		 and dn.docstatus = 1 and dn.is_return = 0 and 
